# Copy this file to .env (git-ignored) and fill in the values.
# Used by docker-compose.

# JWT signing key – must be at least 32 characters.
# Generate a strong key with: openssl rand -base64 48
JWT_KEY=change-me-to-a-strong-secret-of-at-least-32-characters

# Local PostgreSQL settings for docker-compose.
POSTGRES_PORT=55432
POSTGRES_DB=keyless
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
