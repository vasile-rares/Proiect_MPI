# Copy this file to .env (git-ignored) and fill in the values.
# Used by docker-compose.

# JWT signing key – required when starting the backend container via docker-compose.
# Generate a strong key with: openssl rand -base64 48
JWT_KEY=PLACEHOLDER_SET_A_STRONG_SECRET_OF_AT_LEAST_32_CHARACTERS

# Local PostgreSQL settings for docker-compose.
POSTGRES_PORT=55432
POSTGRES_DB=keyless
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
