{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Database (Docker)",
            "type": "node-terminal",
            "request": "launch",
            "command": "docker compose up -d postgres",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Launch Backend",
            "type": "coreclr",
            "request": "launch",
            "program": "dotnet",
            "args": [
                "run",
                "--project",
                "${workspaceFolder}/backend/Keyless.API/Keyless.API.csproj",
                "--launch-profile",
                "http"
            ],
            "cwd": "${workspaceFolder}/backend/Keyless.API",
            "console": "integratedTerminal",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
                "uriFormat": "%s/swagger"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            }
        },
        {
            "name": "Launch Frontend",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "npm",
            "runtimeArgs": ["run", "dev"],
            "cwd": "${workspaceFolder}/frontend",
            "console": "integratedTerminal",
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "Local:\\s+(https?://\\S+)"
            }
        },
        {
            "name": "Debug Tests",
            "type": "coreclr",
            "request": "launch",
            "program": "dotnet",
            "args": [
                "test",
                "${workspaceFolder}/backend/Keyless.Tests/Keyless.Tests.csproj",
                "--verbosity",
                "normal"
            ],
            "cwd": "${workspaceFolder}/backend/Keyless.Tests",
            "console": "integratedTerminal",
            "stopAtEntry": false
        }
    ],
    "compounds": [
        {
            "name": "Launch Fullstack",
            "configurations": ["Launch Backend", "Launch Frontend"],
            "stopAll": true
        }
    ]
}
